# 服务器端口
PORT=3000

# PostgreSQL 数据库连接
DATABASE_URL=postgresql://toefl_user:password@localhost:5432/toefl_db

# Redis 连接
REDIS_URL=redis://localhost:6379

# JWT 密钥
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# OpenAI API（用于口语/写作AI评分）
OPENAI_API_KEY=sk-your-openai-api-key

# 腾讯云配置（用于OCR、COS对象存储）
TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key

# 腾讯云COS配置
OSS_BUCKET=toefl-audio-files
OSS_REGION=ap-guangzhou

# 微信小程序配置
WECHAT_APPID=your-wechat-miniapp-appid
WECHAT_SECRET=your-wechat-miniapp-secret

# 环境
NODE_ENV=development
