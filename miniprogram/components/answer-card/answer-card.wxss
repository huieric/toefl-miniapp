/* components/answer-card/answer-card.wxss */
.answer-card { }

.option-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx; margin-bottom: 16rpx;
  background: #fff; border-radius: 16rpx;
  border: 2rpx solid #eee;
  transition: all 0.2s;
}
.option-item:active { background: #f8f8f8; }

.option-item.selected { border-color: #4A90D9; background: #EDF4FF; }
.option-item.correct { border-color: #52C41A; background: #F6FFED; }
.option-item.wrong { border-color: #FF4D4F; background: #FFF2F0; }

.option-label {
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: #f5f5f5; display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; font-weight: 600; color: #666; flex-shrink: 0;
}
.option-item.selected .option-label { background: #4A90D9; color: #fff; }
.option-item.correct .option-label { background: #52C41A; color: #fff; }
.option-item.wrong .option-label { background: #FF4D4F; color: #fff; }

.option-text { flex: 1; font-size: 28rpx; color: #333; line-height: 1.5; }

.option-icon { font-size: 28rpx; flex-shrink: 0; margin-left: auto; }