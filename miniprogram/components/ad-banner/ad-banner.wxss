/* components/ad-banner/ad-banner.wxss */
.ad-banner {
  position: relative;
  margin: 20rpx 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.ad-image {
  width: 100%;
  height: 160rpx;
  display: block;
}

.ad-label {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.ad-loading {
  margin: 20rpx 24rpx;
}

.ad-placeholder {
  width: 100%;
  height: 160rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: ad-shimmer 1.5s infinite;
  border-radius: 16rpx;
}

@keyframes ad-shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
