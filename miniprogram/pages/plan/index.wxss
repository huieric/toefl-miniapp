/* plan/index.wxss */
.page-plan { min-height: 100vh; }
.countdown-card { background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%); color: #fff; padding: 48rpx 28rpx; }
.countdown-label { font-size: 26rpx; opacity: 0.8; }
.countdown-days { font-size: 96rpx; font-weight: 700; margin: 12rpx 0; line-height: 1; }
.countdown-unit { font-size: 36rpx; font-weight: 400; }
.countdown-date { font-size: 24rpx; opacity: 0.7; margin-top: 8rpx; }

.phase-item { padding: 24rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.phase-item:last-child { border-bottom: none; }
.phase-circle { width: 48rpx; height: 48rpx; border-radius: 50%; background: #f0f0f0; display: flex; align-items: center; justify-content: center; font-size: 24rpx; color: #999; }
.phase-circle.active { background: #4A90D9; color: #fff; }

.daily-entry { padding: 28rpx; margin: 16rpx 24rpx; border-left: 6rpx solid #4A90D9; }

.block { display: block; }
.gap-xs { gap: 8rpx; }