/* plan/setup.wxss */
.page-setup { padding: 24rpx; min-height: 100vh; padding-bottom: 80rpx; }
.setup-header { text-align: center; padding: 40rpx; background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: #fff; }
.setup-icon { font-size: 64rpx; }
.setup-title { font-size: 34rpx; font-weight: 700; display: block; margin-top: 8rpx; }
.setup-desc { font-size: 24rpx; opacity: 0.85; display: block; margin-top: 4rpx; }

.form-item { margin-bottom: 8rpx; }
.form-label { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; display: block; }

.score-btn { padding: 14rpx 28rpx; border-radius: 16rpx; background: #f5f5f5; border: 2rpx solid transparent; font-size: 26rpx; }
.score-btn.active { background: #E3F2FD; border-color: #4A90D9; color: #4A90D9; }

.picker-value { padding: 20rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 28rpx; color: #333; }
.text-hint.picker-value { color: #999; }

.focus-item { padding: 12rpx 28rpx; border-radius: 12rpx; background: #f5f5f5; font-size: 24rpx; color: #666; }
.focus-item.active { background: #4A90D9; color: #fff; }

.btn-lg { height: 96rpx; line-height: 96rpx; font-size: 34rpx; margin-top: 40rpx; }