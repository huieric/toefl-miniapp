/* wrong-book/redo.wxss */
.page-redo { min-height: 100vh; padding: 24rpx; padding-bottom: 180rpx; }
.redo-footer { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1rpx solid #eee; }
.quality-buttons { flex-wrap: wrap; }
.q-btn { flex: 1; min-width: 140rpx; padding: 12rpx 8rpx; font-size: 22rpx; border-radius: 12rpx; background: #f5f5f5; border: none; color: #666; text-align: center; }
.q-btn.active { background: #4A90D9; color: #fff; }