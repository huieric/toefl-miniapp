/* pages/listening/list.wxss */
.page-list { padding-bottom: 40rpx; min-height: 100vh; }

.filter-bar {
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
}

.filter-item.active {
  background: #9C27B0;
  color: #fff;
}

.question-card {
  border-left: 6rpx solid #9C27B0;
}

.question-card:active {
  background: #f8f8f8;
}