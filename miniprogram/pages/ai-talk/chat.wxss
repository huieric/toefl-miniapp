/* ai-talk/chat.wxss */
.page-chat { display: flex; flex-direction: column; height: 100vh; background: #F6F7FB; }
.chat-messages { flex: 1; padding: 24rpx; overflow-y: auto; }
.chat-start { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 60vh; }
.msg-item { margin-bottom: 24rpx; display: flex; }
.msg-user { justify-content: flex-end; }
.msg-ai { justify-content: flex-start; }
.msg-bubble { max-width: 80%; padding: 16rpx 24rpx; border-radius: 20rpx; font-size: 28rpx; line-height: 1.6; }
.bubble-user { background: linear-gradient(135deg, #667eea, #764ba2); color: #fff; border-bottom-right-radius: 6rpx; }
.bubble-ai { background: #fff; color: #333; border-bottom-left-radius: 6rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05); }
.msg-score { margin-top: 8rpx; font-size: 22rpx; }
.msg-correction { margin-top: 4rpx; font-size: 22rpx; }

.chat-input { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 24rpx; background: #fff; border-top: 1rpx solid #eee; }
.voice-btn { width: 72rpx; height: 72rpx; border-radius: 50%; background: #f0f0f0; border: none; font-size: 36rpx; display: flex; align-items: center; justify-content: center; padding: 0; flex-shrink: 0; }
.text-input { flex: 1; height: 72rpx; padding: 0 20rpx; background: #f5f5f5; border-radius: 36rpx; font-size: 28rpx; }
.send-btn { width: 120rpx; height: 72rpx; border-radius: 36rpx; background: #667eea; color: #fff; border: none; font-size: 26rpx; flex-shrink: 0; }