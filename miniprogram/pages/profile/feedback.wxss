/* profile/feedback.wxss */
.page-feedback { padding: 24rpx; min-height: 100vh; }
.form { padding: 32rpx 24rpx; }
.form-label { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 16rpx; display: block; }
.type-item { padding: 14rpx 28rpx; border-radius: 16rpx; background: #f5f5f5; font-size: 26rpx; }
.type-item.active { background: #4A90D9; color: #fff; }
textarea { width: 100%; min-height: 200rpx; padding: 20rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 28rpx; }
input { width: 100%; padding: 20rpx; background: #f5f5f5; border-radius: 12rpx; font-size: 28rpx; }