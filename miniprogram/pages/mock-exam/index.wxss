/* mock-exam/index.wxss */
.page-mock-exam { padding: 24rpx; min-height: 100vh; }
.exam-hero { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%); color: #fff; padding: 48rpx 28rpx; }
.exam-title { font-size: 40rpx; font-weight: 700; margin-bottom: 12rpx; }
.exam-desc { font-size: 26rpx; opacity: 0.8; line-height: 1.6; }
.exam-info { margin-top: 32rpx; }
.info-item { text-align: center; }
.info-num { display: block; font-size: 36rpx; font-weight: 700; }
.info-label { display: block; font-size: 22rpx; opacity: 0.7; margin-top: 4rpx; }
.rule-item { padding: 12rpx 0; font-size: 26rpx; color: #555; }
.rule-num { width: 40rpx; height: 40rpx; background: #f0f0f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 22rpx; flex-shrink: 0; }
.start-btn { height: 100rpx; line-height: 100rpx; font-size: 34rpx; }