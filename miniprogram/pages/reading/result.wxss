/* pages/reading/result.wxss */
.page-result {
  padding: 24rpx;
  padding-bottom: 60rpx;
  min-height: 100vh;
  background: #F6F7FB;
}

.result-header {
  text-align: center;
  padding: 48rpx 28rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #6BA5E7 100%);
  color: #fff;
}

.result-score {
  font-size: 80rpx;
  font-weight: 800;
}

.result-label {
  font-size: 26rpx;
  opacity: 0.85;
  margin-top: 8rpx;
}

.result-meta {
  margin-top: 24rpx;
}

.meta-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.meta-num {
  font-size: 36rpx;
  font-weight: 700;
}

.meta-label {
  font-size: 22rpx;
  opacity: 0.8;
}

.result-detail {
  margin-top: 24rpx;
}

.result-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
}

.dot-correct { background: #52C41A; }
.dot-wrong { background: #FF4D4F; }

.btn-group {
  margin-top: 32rpx;
}