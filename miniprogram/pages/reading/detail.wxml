<!--pages/reading/detail.wxml - 阅读详情页-->
<view class="page-detail" wx:if="{{question}}">
  <!-- 计时器 -->
  <view class="timer-bar flex items-center justify-between p-sm">
    <text class="text-sm text-secondary">阅读练习</text>
    <timer duration="{{20}}" bind:timeout="onTimeUp" />
  </view>

  <!-- 文章区域 -->
  <scroll-view class="article-area" scroll-y style="height: 45vh;">
    <view class="article-title">{{question.title}}</view>
    <view class="article-content">{{question.content}}</view>
  </scroll-view>

  <!-- 题目区域 -->
  <view class="question-area p-md">
    <view class="q-number text-sm text-hint mb-sm">第 {{currentQIndex + 1}} 题 / 共 {{questions.length}} 题</view>
    <view class="q-text card-title">{{currentQuestion.title}}</view>
    <view class="q-content text-secondary mb-md">{{currentQuestion.content}}</view>

    <!-- 选项列表 -->
    <view class="options-list">
      <view
        class="option-item {{selectedAnswer === opt.label ? (opt.label === currentQuestion.answer ? 'correct' : 'wrong') : ''}} {{submitted && opt.label === currentQuestion.answer ? 'correct' : ''}}"
        wx:for="{{currentQuestion.options}}"
        wx:for-item="opt"
        wx:key="label"
        bindtap="selectAnswer"
        data-label="{{opt.label}}"
      >
        <view class="option-label">{{opt.label}}</view>
        <view class="option-text flex-1">{{opt.text}}</view>
        <view class="option-icon" wx:if="{{selectedAnswer === opt.label && submitted}}">
          <text wx:if="{{opt.label === currentQuestion.answer}}">✓</text>
          <text wx:else>✗</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar flex items-center justify-between p-md safe-bottom">
    <button class="btn-outline btn-sm" bindtap="prevQuestion" disabled="{{currentQIndex === 0}}">上一题</button>
    <button class="btn-primary btn-sm" bindtap="submitAnswer" wx:if="{{!submitted}}" disabled="{{!selectedAnswer}}">提交答案</button>
    <button class="btn-primary btn-sm" bindtap="nextQuestion" wx:if="{{submitted}}" disabled="{{currentQIndex === questions.length - 1}}">下一题</button>
    <button class="btn-primary" bindtap="finishPractice" wx:if="{{submitted && currentQIndex === questions.length - 1}}">完成练习</button>
  </view>

  <!-- 解析弹窗 -->
  <view class="analysis-mask" wx:if="{{showAnalysis}}" bindtap="closeAnalysis">
    <view class="analysis-popup" catchtap="">
      <view class="analysis-title">题目解析</view>
      <view class="analysis-content">{{currentQuestion.analysis}}</view>
      <button class="btn-primary btn-block mt-md" bindtap="closeAnalysis">知道了</button>
    </view>
  </view>
</view>