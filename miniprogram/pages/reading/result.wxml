<!--pages/reading/result.wxml - 阅读成绩展示-->
<view class="page-result" wx:if="{{loaded}}">
  <view class="result-header card">
    <view class="result-score">{{score}}</view>
    <view class="result-label">阅读得分（预估）</view>
    <view class="result-meta flex justify-center gap-lg mt-md">
      <view class="meta-item">
        <text class="meta-num text-primary">{{correct}}</text>
        <text class="meta-label">正确</text>
      </view>
      <view class="meta-item">
        <text class="meta-num text-danger">{{wrong}}</text>
        <text class="meta-label">错误</text>
      </view>
      <view class="meta-item">
        <text class="meta-num">{{total}}</text>
        <text class="meta-label">总题数</text>
      </view>
    </view>
  </view>

  <view class="result-detail card">
    <view class="card-title">逐题解析</view>
    <view class="result-item flex items-center justify-between" wx:for="{{results}}" wx:key="index">
      <view class="flex items-center gap-sm flex-1">
        <view class="result-dot {{item.correct ? 'dot-correct' : 'dot-wrong'}}">{{item.correct ? '✓' : '✗'}}</view>
        <text class="text-md">第{{index + 1}}题</text>
      </view>
      <text class="text-sm {{item.correct ? 'text-primary' : 'text-danger'}}">{{item.correct ? '正确' : '错误'}}</text>
    </view>
  </view>

  <view class="btn-group p-md">
    <button class="btn-primary btn-block" bindtap="goBack">继续练习</button>
    <button class="btn-outline btn-block mt-sm" bindtap="goWrong">查看错题</button>
  </view>
</view>