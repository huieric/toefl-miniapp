/* pages/reading/detail.wxss */
.page-detail {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #F6F7FB;
}

.timer-bar {
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.article-area {
  background: #fff;
  padding: 24rpx;
  border-bottom: 1rpx solid #eee;
}

.article-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 20rpx;
}

.article-content {
  font-size: 28rpx;
  color: #444;
  line-height: 1.8;
}

.question-area {
  flex: 1;
  overflow-y: auto;
}

.q-number {
  font-size: 24rpx;
}

.q-text {
  font-size: 30rpx;
  margin-bottom: 12rpx;
}

.q-content {
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

/* 选项 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.option-item:active {
  background: #f0f7ff;
}

.option-item.correct {
  border-color: #52C41A;
  background: #F0FFF0;
}

.option-item.wrong {
  border-color: #FF4D4F;
  background: #FFF0F0;
}

.option-label {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  font-size: 26rpx;
  flex-shrink: 0;
}

.option-item.correct .option-label {
  background: #52C41A;
  color: #fff;
}

.option-item.wrong .option-label {
  background: #FF4D4F;
  color: #fff;
}

.option-text {
  font-size: 28rpx;
  color: #333;
}

.option-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.option-item.correct .option-icon { color: #52C41A; }
.option-item.wrong .option-icon { color: #FF4D4F; }

/* 底部操作栏 */
.bottom-bar {
  background: #fff;
  border-top: 1rpx solid #eee;
}

/* 解析弹窗 */
.analysis-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.analysis-popup {
  width: 85%;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
}

.analysis-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.analysis-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.7;
}